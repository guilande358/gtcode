{
  "compileOnSave": true,
  "include": ["./src/**/*"],
  "compilerOptions": {
    "outDir": "./build",
    "importHelpers": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  }
}
